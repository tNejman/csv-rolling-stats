{
  "version": 3,
  "configurePresets": [
    {
      "name": "gcc-make-ld",
      "displayName": "gcc-make-ld",
      "description": "",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "clang-ninja-lld",
      "displayName": "clang-ninja-lld",
      "description": "",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_EXE_LINKER_FLAGS": "-fuse-ld=lld"
      }
    }
  ]
}
